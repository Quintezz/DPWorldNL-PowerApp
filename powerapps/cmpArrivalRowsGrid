            - btnRowGridSave:
                Control: Classic/Icon@2.5.0
                Group: ActionButtons
                Properties:
                  BorderColor: =RGBA(0, 89, 178, 1)
                  Color: =cmpArrivalRowsGrid.cpyHeaderTextColor
                  Height: =cmpArrivalRowsGrid.cpyButtonHeight
                  HoverColor: =cmpArrivalRowsGrid.cpyAccentColor
                  Icon: =Icon.Save
                  OnSelect: |-
                    =If(
                        IsBlank(Trim(txtRowGridPartNo.Text)) ||
                        IsBlank(drpRowGridSupplier.Selected.PrimairySupplier) ||
                        IsBlank(Trim(txtRowGridQuantity.Text)) ||
                        !IsNumeric(txtRowGridQuantity.Text) ||
                        Value(txtRowGridQuantity.Text) <= 0,
                        Notify(
                            "Part Number, Supplier and a Quantity greater than 0 are required.",
                            NotificationType.Error
                        ),
                        With(
                            {
                                _incomingRaw: Trim(txtRowGridIncoming.Text),
                                _asnRaw: Trim(txtRowGridAsn.Text)
                            },
                            With(
                                {
                                    _incomingToSave: If(
                                        IsBlank(_incomingRaw) || _incomingRaw = "NoInc",
                                        "NoInc",
                                        If(
                                            IsMatch(_incomingRaw, "^[0-9]{6}$"),
                                            _incomingRaw,
                                            Blank()
                                        )
                                    ),
                                    _asnToSave: If(
                                        IsBlank(_asnRaw) || _asnRaw = "NoASN",
                                        "NoASN",
                                        If(
                                            IsMatch(_asnRaw, "^[0-9]{6}$"),
                                            _asnRaw,
                                            Blank()
                                        )
                                    )
                                },
                                If(
                                    IsBlank(_incomingToSave),
                                    Notify(
                                        "Incoming must be 'NoInc' or exactly 6 digits.",
                                        NotificationType.Error
                                    ),
                                    If(
                                        IsBlank(_asnToSave),
                                        Notify(
                                            "ASN must be 'NoASN' or exactly 6 digits.",
                                            NotificationType.Error
                                        ),
                                        With(
                                            {
                                                _statusIdToSave: If(
                                                    drpRowGridSupplier.Selected.PrimairySupplier = "N/A",
                                                    LookUp(
                                                        ArrivalRowStatus,
                                                        Code = "NOT_SETUP",
                                                        ID
                                                    ),
                                                    drpRowGridStatus.Selected.ID
                                                ),
                                                _nextRowSequence: Coalesce(
                                                    Max(
                                                        Filter(
                                                            ArrivalRowsUnreleased,
                                                            ParentHeaderDbID = cmpArrivalRowsGrid.cpySelectedHeaderDbID
                                                        ),
                                                        RowSequence
                                                    ),
                                                    0
                                                ) + 1
                                            },
                                            If(
                                                IsBlank(_statusIdToSave),
                                                Notify(
                                                    "Status could not be determined.",
                                                    NotificationType.Error
                                                ),
                                                IfError(
                                                    With(
                                                        {
                                                            _saved: If(
                                                                ThisItem.ID = -1,
                                                                Patch(
                                                                    ArrivalRowsUnreleased,
                                                                    Defaults(ArrivalRowsUnreleased),
                                                                    {
                                                                        ParentHeaderDbID: cmpArrivalRowsGrid.cpySelectedHeaderDbID,
                                                                        HeaderRecordID: cmpArrivalRowsGrid.cpySelectedHeaderID,
                                                                        RowSequence: _nextRowSequence,
                                                                        PartNumber: Trim(txtRowGridPartNo.Text),
                                                                        PrimairySupplier: drpRowGridSupplier.Selected.PrimairySupplier,
                                                                        Quantity: Value(txtRowGridQuantity.Text),
                                                                        DellOwned: If(
                                                                            Lower(Trim(txtRowGridDellOwned.Text)) = "true" ||
                                                                            Lower(Trim(txtRowGridDellOwned.Text)) = "yes" ||
                                                                            Trim(txtRowGridDellOwned.Text) = "1",
                                                                            true,
                                                                            false
                                                                        ),
                                                                        Container: Trim(txtRowGridContainer.Text),
                                                                        Incoming: _incomingToSave,
                                                                        ASN: _asnToSave,
                                                                        MRN: Trim(txtRowGridMrn.Text),
                                                                        StatusID: _statusIdToSave
                                                                    }
                                                                ),
                                                                Patch(
                                                                    ArrivalRowsUnreleased,
                                                                    LookUp(
                                                                        ArrivalRowsUnreleased,
                                                                        ID = ThisItem.ID
                                                                    ),
                                                                    {
                                                                        PartNumber: Trim(txtRowGridPartNo.Text),
                                                                        PrimairySupplier: drpRowGridSupplier.Selected.PrimairySupplier,
                                                                        Quantity: Value(txtRowGridQuantity.Text),
                                                                        DellOwned: If(
                                                                            Lower(Trim(txtRowGridDellOwned.Text)) = "true" ||
                                                                            Lower(Trim(txtRowGridDellOwned.Text)) = "yes" ||
                                                                            Trim(txtRowGridDellOwned.Text) = "1",
                                                                            true,
                                                                            false
                                                                        ),
                                                                        Container: Trim(txtRowGridContainer.Text),
                                                                        Incoming: _incomingToSave,
                                                                        ASN: _asnToSave,
                                                                        MRN: Trim(txtRowGridMrn.Text),
                                                                        StatusID: _statusIdToSave
                                                                    }
                                                                )
                                                            )
                                                        },
                                                        Concurrent(
                                                            Refresh(ArrivalRowsUnreleased),
                                                            Reset(txtRowGridPartNo),
                                                            Reset(drpRowGridSupplier),
                                                            Reset(txtRowGridQuantity),
                                                            Reset(txtRowGridDellOwned),
                                                            Reset(txtRowGridContainer),
                                                            Reset(txtRowGridIncoming),
                                                            Reset(txtRowGridAsn),
                                                            Reset(txtRowGridMrn),
                                                            Reset(drpRowGridStatus),
                                                            ClearCollect(
                                                                colVendorChoices,
                                                                Table(
                                                                    { PrimairySupplier: "N/A" }
                                                                )
                                                            ),
                                                            Set(varEditingRowID, Blank()),
                                                            Set(varAddingRow, false),
                                                            Set(varSelectedRowDbId, _saved.ID),
                                                            Set(varIPActivityMode, "RowComments")
                                                        )
                                                    ),
                                                    Notify(
                                                        FirstError.Message,
                                                        NotificationType.Error
                                                    )
                                                )
                                            )
                                        )
                                    )
                                )
                            )
                        )
                    )
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =cmpArrivalRowsGrid.cpyButtonHeight
                  X: =lblRowGridHdrActions.X + 5
                  Y: =(Parent.TemplateHeight - Self.Height) / 2
