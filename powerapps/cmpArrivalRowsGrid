ComponentDefinitions:
  cmpArrivalRowsGrid:
    DefinitionType: CanvasComponent
    AccessAppScope: true
    CustomProperties:
      cpyAccentColor:
        PropertyKind: Input
        DisplayName: cpyAccentColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(0, 89, 178, 1)
      cpyBodyTextColor:
        PropertyKind: Input
        DisplayName: cpyBodyTextColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(16, 24, 40, 1)
      cpyBorderColor:
        PropertyKind: Input
        DisplayName: cpyBorderColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(228, 232, 240, 1)
      cpyButtonHeight:
        PropertyKind: Input
        DisplayName: cpyButtonHeight
        Description: A custom property
        DataType: Number
        Default: |+
          =28
      cpyButtonTextColor:
        PropertyKind: Input
        DisplayName: cpyButtonTextColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(255, 255, 255, 1)
      cpyControlHoverFill:
        PropertyKind: Input
        DisplayName: cpyControlHoverFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(153, 205, 255, 1)
      cpyCornerRadius:
        PropertyKind: Input
        DisplayName: cpyCornerRadius
        Description: A custom property
        DataType: Number
        Default: =8
      cpyDangerButtonFill:
        PropertyKind: Input
        DisplayName: cpyDangerButtonFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(239, 68, 68, 1)
      cpyDividerColor:
        PropertyKind: Input
        DisplayName: cpyDividerColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(234, 236, 240, 1)
      cpyDropdownBackgroundFill:
        PropertyKind: Input
        DisplayName: cpyDropdownBackgroundFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(248, 250, 252, 1)
      cpyEditorHeight:
        PropertyKind: Input
        DisplayName: cpyEditorHeight
        Description: A custom property
        DataType: Number
        Default: =34
      cpyFontSize:
        PropertyKind: Input
        DisplayName: cpyFontSize
        Description: A custom property
        DataType: Number
        Default: =11
      cpyHeaderFill:
        PropertyKind: Input
        DisplayName: cpyHeaderFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(249, 250, 251, 1)
      cpyHeaderHeight:
        PropertyKind: Input
        DisplayName: cpyHeaderHeight
        Description: A custom property
        DataType: Number
        Default: =40
      cpyHeaderTextColor:
        PropertyKind: Input
        DisplayName: cpyHeaderTextColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(52, 64, 84, 1)
      cpyInputBorderColor:
        PropertyKind: Input
        DisplayName: cpyInputBorderColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(208, 213, 221, 1)
      cpyLargeColumnWidth:
        PropertyKind: Input
        DisplayName: cpyLargeColumnWidth
        Description: A custom property
        DataType: Number
        Default: =140
      cpyMediumColumnWidth:
        PropertyKind: Input
        DisplayName: cpyMediumColumnWidth
        Description: A custom property
        DataType: Number
        Default: =100
      cpyNarrowColumnWidth:
        PropertyKind: Input
        DisplayName: cpyNarrowColumnWidth
        Description: A custom property
        DataType: Number
        Default: =80
      cpyNeutralButtonFill:
        PropertyKind: Input
        DisplayName: cpyNeutralButtonFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(107, 114, 128, 1)
      cpyPrimaryButtonFill:
        PropertyKind: Input
        DisplayName: cpyPrimaryButtonFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(0, 89, 178, 1)
      cpyRowHeight:
        PropertyKind: Input
        DisplayName: cpyRowHeight
        Description: A custom property
        DataType: Number
        Default: |+
          =40
      cpySelectedHeaderDbID:
        PropertyKind: Input
        DisplayName: cpySelectedHeaderDbID
        Description: A custom property
        DataType: Number
        Default: =100
      cpySelectedHeaderID:
        PropertyKind: Input
        DisplayName: cpySelectedHeaderID
        Description: A custom property
        DataType: Text
        Default: ="Text"
      cpySelectedRowFill:
        PropertyKind: Input
        DisplayName: cpySelectedRowFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(230, 242, 255, 1)
      cpyStatusIssueFill:
        PropertyKind: Input
        DisplayName: cpyStatusIssueFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(254, 243, 242, 1)
      cpyStatusReviewFill:
        PropertyKind: Input
        DisplayName: cpyStatusReviewFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(255, 241, 230, 1)
      cpyStatusWarningFill:
        PropertyKind: Input
        DisplayName: cpyStatusWarningFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(255, 250, 235, 1)
      cpySurfaceFill:
        PropertyKind: Input
        DisplayName: cpySurfaceFill
        Description: A custom property
        DataType: Color
        Default: =RGBA(255, 255, 255, 1)
      cpyValidationErrorColor:
        PropertyKind: Input
        DisplayName: cpyValidationErrorColor
        Description: A custom property
        DataType: Color
        Default: =RGBA(239, 68, 68, 1)
    Properties:
      Height: =500
      Width: =1200
    Children:
      - galRowGridRows:
          Control: Gallery@2.15.0
          Variant: BrowseLayout_Vertical_TwoTextOneImageVariant_ver5.0
          Properties:
            AccessibleLabel: ="Rows"
            BorderColor: =cmpArrivalRowsGrid.cpyAccentColor
            Fill: =cmpArrivalRowsGrid.cpyHeaderFill
            Height: =Parent.Height - conRowGridHeader.Height - conRowGridTopBar.Height
            Items: |-
              =If(
                  varAddingRow,
                  colRowsDisplayIP,
                  SortByColumns(
                      Filter(
                          ArrivalRowsUnreleased,
                          ParentHeaderDbID = cmpArrivalRowsGrid.cpySelectedHeaderDbID
                      ),
                      "ID",
                      SortOrder.Descending
                  )
              )
            OnSelect: |-
              =If(
                  IsBlank(varEditingRowID) && !varAddingRow,
                  Concurrent(
                      Set(varSelectedRowDbId, ThisItem.ID),
                      Set(varIPActivityMode, "RowComments")
                  )
              )
            TemplateFill: |-
              =If(
                  ThisItem.ID = varSelectedRowDbId,
                  cmpArrivalRowsGrid.cpySelectedRowFill,
                  cmpArrivalRowsGrid.cpySurfaceFill
              )
            TemplateSize: =cmpArrivalRowsGrid.cpyRowHeight
            Width: =Parent.Width
            Y: =conRowGridTopBar.Height + conRowGridHeader.Height
          Children:
            - lblRowGridPartNo:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |+
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: =ThisItem.PartNumber
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrPartNo.Width
            - lblRowGridSupplier:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |+
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: =ThisItem.PrimairySupplier
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrSupplier.Width
                  X: |+
                    =lblRowGridHdrSupplier.X
            - lblRowGridQuantity:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |+
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: =ThisItem.Quantity
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrQuantity.Width
                  X: |
                    =lblRowGridHdrQuantity.X
            - btnRowGridSelect:
                Control: Classic/Button@2.2.0
                Group: VariousAdd
                Properties:
                  BorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  BorderThickness: =0
                  Color: =cmpArrivalRowsGrid.cpyButtonTextColor
                  DisabledBorderColor: =cmpArrivalRowsGrid.cpyBorderColor
                  Fill: =Color.Transparent
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight
                  HoverBorderColor: =ColorFade(Self.BorderColor, 20%)
                  HoverColor: =Color.Transparent
                  HoverFill: =Color.Transparent
                  OnSelect: |-
                    =
                    Concurrent(
                        Set(varSelectedRowDbId, ThisItem.ID),
                        Set(varIPActivityMode, "RowComments")
                    )
                  PaddingBottom: =0
                  PaddingLeft: =0
                  PaddingRight: =0
                  PaddingTop: =0
                  PressedBorderColor: =Self.Fill
                  PressedColor: =Color.Transparent
                  PressedFill: =Color.Transparent
                  Size: =11
                  Text: =
                  Visible: =IsBlank(varEditingRowID) && !varAddingRow
                  Width: =Parent.Width
                  Y: =Parent.TemplateHeight - Self.Height
            - recRowGridDivider:
                Control: Rectangle@2.3.0
                Group: VariousAdd
                Properties:
                  BorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  Fill: =cmpArrivalRowsGrid.cpyDividerColor
                  Height: =1
                  HoverFill: =
                  OnSelect: =Select(Parent)
                  Width: =Parent.TemplateWidth
                  Y: =Parent.TemplateHeight - Self.Height
            - lblRowGridDellOwned:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |+
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: |-
                    =If(
                        ThisItem.DellOwned,
                        "Yes",
                        "No"
                    )
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrDellOwned.Width
                  X: |
                    =lblRowGridHdrDellOwned.X
            - lblRowGridContainer:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |+
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: =ThisItem.Container
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrContainer.Width
                  X: |
                    =lblRowGridHdrContainer.X
            - lblRowGridIncoming:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: =Coalesce(ThisItem.Incoming, "NoInc")
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrIncoming.Width
                  X: |
                    =lblRowGridHdrIncoming.X
            - lblRowGridAsn:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: =Coalesce(ThisItem.ASN, "NoASN")
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrAsn.Width
                  X: =lblRowGridHdrAsn.X
            - lblRowGridMrn:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: =Coalesce(ThisItem.MRN, "NoMRN")
                  Visible: =ThisItem.ID <> varEditingRowID && !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrMrn.Width
                  X: |
                    =lblRowGridHdrMrn.X
            - lblRowGridStatus:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |+
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: |-
                    =Coalesce(
                        LookUp(
                           ArrivalRowStatus,
                            ID = Value(ThisItem.StatusID),
                            Name
                        ),
                        Text(ThisItem.StatusID)
                    )
                  Visible: =false
                  Width: =lblRowGridHdrStatus.Width
                  X: =lblRowGridHdrStatus.X
            - lblRowGridComment:
                Control: Label@2.5.1
                Group: ViewLabels
                Properties:
                  Align: =Align.Center
                  BorderColor: =Color.Transparent
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyRowHeight - 1
                  OnSelect: |+
                    =Select(Parent)
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Text: |-
                    ="💬"
                  Visible: |-
                    =ThisItem.HasComment &&
                    ThisItem.ID <> varEditingRowID &&
                    !(varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrComment.Width
                  X: =lblRowGridHdrComment.X
            - txtRowGridPartNo:
                Control: Classic/TextInput@2.3.2
                Group: EditInputs
                Properties:
                  Align: =Align.Center
                  BorderColor: =cmpArrivalRowsGrid.cpyInputBorderColor
                  BorderThickness: =1
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: =ThisItem.PartNumber
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  OnChange: |-
                    =ClearCollect(
                        colVendorChoices,
                        SortByColumns(
                            RenameColumns(
                                ShowColumns(
                                    Filter(
                                        AlternativeSupplier,
                                        PartNo = Trim(txtRowGridPartNo.Text)
                                    ),
                                    AlternativeSupplier
                                ),
                                AlternativeSupplier,
                                PrimairySupplier
                            ),
                            "PrimairySupplier",
                            SortOrder.Ascending
                        )
                    );
                    If(
                        CountRows(colVendorChoices) = 0,
                        ClearCollect(
                            colVendorChoices,
                            Table(
                                { PrimairySupplier: "N/A" }
                            )
                        )
                    );
                    Reset(drpRowGridSupplier);
                    Reset(drpRowGridStatus)
                  OnSelect: =Select(Parent)
                  RadiusBottomLeft: =0
                  RadiusBottomRight: =0
                  RadiusTopLeft: =0
                  RadiusTopRight: =0
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrPartNo.Width
                  X: =lblRowGridPartNo.X
            - txtRowGridQuantity:
                Control: Classic/TextInput@2.3.2
                Group: EditInputs
                Properties:
                  Align: =Align.Center
                  BorderColor: =cmpArrivalRowsGrid.cpyInputBorderColor
                  BorderThickness: =1
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: =Text(ThisItem.Quantity)
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  OnSelect: =Select(Parent)
                  RadiusBottomLeft: =0
                  RadiusBottomRight: =0
                  RadiusTopLeft: =0
                  RadiusTopRight: =0
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrQuantity.Width
                  X: =lblRowGridQuantity.X
            - txtRowGridDellOwned:
                Control: Classic/TextInput@2.3.2
                Group: EditInputs
                Properties:
                  Align: =Align.Center
                  BorderColor: =cmpArrivalRowsGrid.cpyInputBorderColor
                  BorderThickness: =1
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: |-
                    =If(
                        ThisItem.DellOwned,
                        "Yes",
                        "No"
                    )
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HintText: ="Yes / No"
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  OnSelect: =Select(Parent)
                  RadiusBottomLeft: =0
                  RadiusBottomRight: =0
                  RadiusTopLeft: =0
                  RadiusTopRight: =0
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrDellOwned.Width
                  X: =lblRowGridDellOwned.X
            - txtRowGridContainer:
                Control: Classic/TextInput@2.3.2
                Group: EditInputs
                Properties:
                  Align: =Align.Center
                  BorderColor: =cmpArrivalRowsGrid.cpyInputBorderColor
                  BorderThickness: =1
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: =ThisItem.Container
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  OnSelect: =Select(Parent)
                  RadiusBottomLeft: =0
                  RadiusBottomRight: =0
                  RadiusTopLeft: =0
                  RadiusTopRight: =0
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridContainer.Width
                  X: =lblRowGridContainer.X
            - txtRowGridIncoming:
                Control: Classic/TextInput@2.3.2
                Group: EditInputs
                Properties:
                  Align: =Align.Center
                  BorderColor: |-
                    =If(
                        IsBlank(Trim(Self.Text)) ||
                        Trim(Self.Text) = "NoInc" ||
                        IsMatch(Trim(Self.Text), "^[0-9]{6}$"),
                        cmpArrivalRowsGrid.cpyInputBorderColor,
                        cmpArrivalRowsGrid.cpyValidationErrorColor
                    )
                  BorderThickness: =1
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: =Coalesce(ThisItem.Incoming, "NoInc")
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HintText: ="NoInc or 6 Digits"
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  OnSelect: =Select(Parent)
                  RadiusBottomLeft: =0
                  RadiusBottomRight: =0
                  RadiusTopLeft: =0
                  RadiusTopRight: =0
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Tooltip: ="Incoming is optional when creating an arrival, but required for release. Use NoInc or 6 digits."
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrIncoming.Width
                  X: =lblRowGridHdrIncoming.X
                  Y: =1
            - txtRowGridAsn:
                Control: Classic/TextInput@2.3.2
                Group: EditInputs
                Properties:
                  Align: =Align.Center
                  BorderColor: |-
                    =If(
                        IsBlank(Trim(Self.Text)) ||
                        Trim(Self.Text) = "NoASN" ||
                        IsMatch(Trim(Self.Text), "^[0-9]{6}$"),
                        cmpArrivalRowsGrid.cpyInputBorderColor,
                        cmpArrivalRowsGrid.cpyValidationErrorColor
                    )
                  BorderThickness: =1
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: =Coalesce(ThisItem.ASN, "NoASN")
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HintText: ="NoASN or 6 digits"
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  OnSelect: =Select(Parent)
                  RadiusBottomLeft: =0
                  RadiusBottomRight: =0
                  RadiusTopLeft: =0
                  RadiusTopRight: =0
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrAsn.Width
                  X: =lblRowGridHdrAsn.X
                  Y: =1
            - txtRowGridMrn:
                Control: Classic/TextInput@2.3.2
                Group: EditInputs
                Properties:
                  Align: =Align.Center
                  BorderColor: =cmpArrivalRowsGrid.cpyInputBorderColor
                  BorderThickness: =1
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: =Coalesce(ThisItem.MRN, "NoMRN")
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HintText: ="NoMRN"
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  OnSelect: =Select(Parent)
                  RadiusBottomLeft: =0
                  RadiusBottomRight: =0
                  RadiusTopLeft: =0
                  RadiusTopRight: =0
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrMrn.Width
                  X: =lblRowGridHdrMrn.X
                  Y: =1
            - drpRowGridSupplier:
                Control: Classic/DropDown@2.3.1
                Group: EditInputs
                Properties:
                  BorderColor: =cmpArrivalRowsGrid.cpyInputBorderColor
                  BorderThickness: =1
                  ChevronBackground: =cmpArrivalRowsGrid.cpyDropdownBackgroundFill
                  ChevronFill: =cmpArrivalRowsGrid.cpyHeaderTextColor
                  ChevronHoverBackground: =cmpArrivalRowsGrid.cpyDropdownBackgroundFill
                  ChevronHoverFill: =cmpArrivalRowsGrid.cpyButtonTextColor
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: |-
                    =If(
                        CountRows(Filter(colVendorChoices, PrimairySupplier = ThisItem.PrimairySupplier)) > 0,
                        ThisItem.PrimairySupplier,
                        If(
                            CountRows(colVendorChoices) = 1 && First(colVendorChoices).PrimairySupplier = "N/A",
                            "N/A",
                            Blank()
                        )
                    )
                  Font: =Font.'Open Sans'
                  Height: =cmpArrivalRowsGrid.cpyEditorHeight
                  HoverBorderColor: =cmpArrivalRowsGrid.cpyAccentColor
                  HoverFill: =cmpArrivalRowsGrid.cpyControlHoverFill
                  Items: =colVendorChoices
                  Items.Value: =PrimairySupplier
                  OnSelect: =Select(Parent)
                  PressedColor: =cmpArrivalRowsGrid.cpyButtonTextColor
                  PressedFill: =cmpArrivalRowsGrid.cpyAccentColor
                  SelectionColor: =cmpArrivalRowsGrid.cpyButtonTextColor
                  SelectionFill: =cmpArrivalRowsGrid.cpyAccentColor
                  Size: =cmpArrivalRowsGrid.cpyFontSize
                  Visible: =ThisItem.ID = varEditingRowID || (varAddingRow && ThisItem.ID = -1)
                  Width: =lblRowGridHdrSupplier.Width
                  X: =lblRowGridSupplier.X
            - drpRowGridStatus:
                Control: Classic/DropDown@2.3.1
                Group: EditInputs
                Properties:
                  BorderColor: =cmpArrivalRowsGrid.cpyInputBorderColor
                  BorderThickness: =1
                  ChevronBackground: =cmpArrivalRowsGrid.cpyDropdownBackgroundFill
                  ChevronFill: =cmpArrivalRowsGrid.cpyHeaderTextColor
                  ChevronHoverBackground: =cmpArrivalRowsGrid.cpyDropdownBackgroundFill
                  ChevronHoverFill: =cmpArrivalRowsGrid.cpyButtonTextColor
                  Color: =cmpArrivalRowsGrid.cpyBodyTextColor
                  Default: |-
                    =If(
                        drpRowGridSupplier.Selected.PrimairySupplier = "N/A" ||
                        (CountRows(colVendorChoices) = 1 && First(colVendorChoices).PrimairySupplier = "N/A"),
                        LookUp(
                            ArrivalRowStatus,
                            Code = "NOT_SETUP",
                            Name
                        ),
                        Coalesce(
                            LookUp(
                                ArrivalRowStatus,
                                ID = Value(ThisItem.StatusID),
                                Name
                            ),
                            LookUp(
                                ArrivalRowStatus,
                                IsActive = true && SortOrder = 1,
                                Name
                            )
                        )
                    )
                  DisplayMode: |-
                    =If(
